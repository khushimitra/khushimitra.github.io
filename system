<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wheeltrix - Feedback & Management System</title>
    <!-- Tailwind CSS for modern, professional styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A', // Deep Navy
                        secondary: '#1E293B', // Slate Blue
                        accent: '#6366F1', // Indigo Accent
                        lightbg: '#F8FAFC',
                    }
                }
            }
        }
    </script>
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-lightbg text-slate-700 font-sans antialiased min-h-screen flex flex-col">

    <!-- Top Navigation Bar -->
    <header class="bg-primary text-white shadow-md sticky top-0 z-50 flex justify-between items-center px-6 py-4">
        <div class="flex items-center space-x-3">
            <div class="bg-accent text-white p-2 rounded-lg font-bold text-xl flex items-center justify-center w-10 h-10">
                <i class="fa-solid fa-gauge-high"></i>
            </div>
            <span class="text-xl font-bold tracking-wide">Wheeltrix <span class="text-accent text-sm font-normal">Feedback System</span></span>
        </div>
        <div class="flex items-center space-x-4">
            <!-- Notification Bell with Badge -->
            <button onclick="switchTab('notifications')" class="relative text-slate-300 hover:text-white transition">
                <i class="fa-solid fa-bell text-xl"></i>
                <span id="notif-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center">2</span>
            </button>
            <div class="flex items-center space-x-2 border-l border-slate-700 pl-4">
                <span id="user-role-badge" class="bg-slate-800 text-xs px-2.5 py-1 rounded-full text-slate-300 border border-slate-700">Guest User</span>
            </div>
        </div>
    </header>

    <div class="flex flex-1">
        <!-- Sidebar Navigation -->
        <aside class="w-64 bg-secondary text-slate-300 hidden md:flex flex-col justify-between p-4 shadow-lg">
            <nav class="space-y-1">
                <a href="#" onclick="switchTab('dashboard')" id="nav-dashboard" class="tab-btn flex items-center space-x-3 px-4 py-3 rounded-lg bg-accent text-white font-medium transition">
                    <i class="fa-solid fa-house w-5"></i>
                    <span>Dashboard</span>
                </a>
                <a href="#" onclick="switchTab('submit-feedback')" id="nav-submit-feedback" class="tab-btn flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-slate-800 hover:text-white transition">
                    <i class="fa-solid fa-pen-to-square w-5"></i>
                    <span>Submit Feedback</span>
                </a>
                <a href="#" onclick="switchTab('my-feedback')" id="nav-my-feedback" class="tab-btn flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-slate-800 hover:text-white transition">
                    <i class="fa-solid fa-list-check w-5"></i>
                    <span>My Submissions</span>
                </a>
                <a href="#" onclick="switchTab('notifications')" id="nav-notifications" class="tab-btn flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-slate-800 hover:text-white transition">
                    <i class="fa-solid fa-bell w-5"></i>
                    <span>Notifications</span>
                </a>
                <a href="#" onclick="switchTab('admin-panel')" id="nav-admin-panel" class="tab-btn flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-slate-800 hover:text-white transition text-amber-400">
                    <i class="fa-solid fa-shield-halved w-5"></i>
                    <span>Admin Panel</span>
                </a>
            </nav>
            <div class="pt-4 border-t border-slate-800">
                <a href="#" onclick="switchTab('auth')" id="nav-auth" class="flex items-center space-x-3 px-4 py-3 rounded-lg bg-slate-800 text-slate-200 hover:bg-slate-700 transition">
                    <i class="fa-solid fa-right-to-bracket w-5"></i>
                    <span id="auth-btn-text">Login / Register</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 p-6 md:p-10 max-w-7xl mx-auto overflow-y-auto">

            <!-- 1. Dashboard Tab -->
            <section id="tab-dashboard" class="tab-content space-y-6">
                <div>
                    <h1 class="text-2xl font-bold text-primary">Welcome to Wheeltrix Portal</h1>
                    <p class="text-slate-500">Monitor client feedback, system analytics, and track resolution statuses seamlessly.</p>
                </div>
                <!-- Analytics Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500">Total Feedbacks</p>
                            <h3 class="text-3xl font-bold text-primary mt-1">128</h3>
                        </div>
                        <div class="bg-indigo-50 text-accent p-4 rounded-xl text-xl"><i class="fa-solid fa-comments"></i></div>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500">Resolved</p>
                            <h3 class="text-3xl font-bold text-emerald-600 mt-1">94</h3>
                        </div>
                        <div class="bg-emerald-50 text-emerald-600 p-4 rounded-xl text-xl"><i class="fa-solid fa-circle-check"></i></div>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500">In Progress</p>
                            <h3 class="text-3xl font-bold text-amber-500 mt-1">24</h3>
                        </div>
                        <div class="bg-amber-50 text-amber-500 p-4 rounded-xl text-xl"><i class="fa-solid fa-clock"></i></div>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500">Satisfaction Score</p>
                            <h3 class="text-3xl font-bold text-blue-600 mt-1">4.8/5</h3>
                        </div>
                        <div class="bg-blue-50 text-blue-600 p-4 rounded-xl text-xl"><i class="fa-solid fa-star"></i></div>
                    </div>
                </div>
            </section>

            <!-- 2. Submit Feedback Tab -->
            <section id="tab-submit-feedback" class="tab-content hidden space-y-6">
                <div>
                    <h1 class="text-2xl font-bold text-primary">Submit New Feedback</h1>
                    <p class="text-slate-500">Help us improve our service standards by sharing your experience or reporting bugs.</p>
                </div>
                <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200 max-w-2xl">
                    <form id="feedbackForm" onsubmit="handleFeedbackSubmit(event)" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Feedback Category</label>
                            <select id="fb-category" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent outline-none">
                                <option value="Product">Product Feature Request</option>
                                <option value="Service">Customer Support Service</option>
                                <option value="Bug">Bug / Technical Issue</option>
                                <option value="General">General Comments</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Subject / Title</label>
                            <input type="text" id="fb-title" required placeholder="e.g., Dashboard loading speed issue" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Detailed Description</label>
                            <textarea id="fb-desc" rows="4" required placeholder="Provide as much detail as possible..." class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-accent text-white py-3 rounded-lg font-medium hover:bg-indigo-700 transition shadow-sm">Submit Feedback</button>
                    </form>
                </div>
            </section>

            <!-- 3. My Submissions Tab -->
            <section id="tab-my-feedback" class="tab-content hidden space-y-6">
                <div>
                    <h1 class="text-2xl font-bold text-primary">My Submissions</h1>
                    <p class="text-slate-500">Track current status and updates regarding your submitted requests.</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase text-slate-500 font-semibold">
                                <th class="p-4">ID</th>
                                <th class="p-4">Category</th>
                                <th class="p-4">Subject</th>
                                <th class="p-4">Status</th>
                            </tr>
                        </thead>
                        <tbody id="my-feedback-list" class="divide-y divide-slate-100 text-sm">
                            <tr class="hover:bg-slate-50">
                                <td class="p-4 font-medium text-slate-900">#TW-101</td>
                                <td class="p-4">Product</td>
                                <td class="p-4">Dark mode support in analytics tab</td>
                                <td class="p-4"><span class="bg-amber-50 text-amber-600 px-2.5 py-1 rounded-full text-xs font-semibold">In Progress</span></td>
                            </tr>
                            <tr class="hover:bg-slate-50">
                                <td class="p-4 font-medium text-slate-900">#TW-089</td>
                                <td class="p-4">Bug</td>
                                <td class="p-4">Export CSV button timeout</td>
                                <td class="p-4"><span class="bg-emerald-50 text-emerald-600 px-2.5 py-1 rounded-full text-xs font-semibold">Resolved</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- 4. Notifications Tab -->
            <section id="tab-notifications" class="tab-content hidden space-y-6">
                <div>
                    <h1 class="text-2xl font-bold text-primary">System Notifications</h1>
                    <p class="text-slate-500">Stay updated with system broadcasts and status updates.</p>
                </div>
                <div class="space-y-3 max-w-3xl">
                    <div class="bg-white p-4 rounded-xl shadow-sm border-l-4 border-accent flex items-start justify-between">
                        <div>
                            <h4 class="font-semibold text-primary">Feedback #TW-089 Resolved</h4>
                            <p class="text-sm text-slate-500 mt-0.5">Your bug report regarding CSV exports has been fixed and deployed.</p>
                        </div>
                        <span class="text-xs text-slate-400">2h ago</span>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-sm border-l-4 border-amber-500 flex items-start justify-between">
                        <div>
                            <h4 class="font-semibold text-primary">System Maintenance Notice</h4>
                            <p class="text-sm text-slate-500 mt-0.5">Scheduled maintenance will take place this Sunday at 02:00 AM UTC.</p>
                        </div>
                        <span class="text-xs text-slate-400">Yesterday</span>
                    </div>
                </div>
            </section>

            <!-- 5. Admin Panel Tab -->
            <section id="tab-admin-panel" class="tab-content hidden space-y-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h1 class="text-2xl font-bold text-primary">Admin Control Panel</h1>
                        <p class="text-slate-500">Manage user feedback, alter statuses, and broadcast alerts.</p>
                    </div>
                    <button onclick="alert('Broadcast sent successfully!')" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-800 transition">Broadcast Alert</button>
                </div>
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase text-slate-500 font-semibold">
                                <th class="p-4">ID</th>
                                <th class="p-4">Category</th>
                                <th class="p-4">Subject</th>
                                <th class="p-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="admin-feedback-list" class="divide-y divide-slate-100 text-sm">
                            <tr class="hover:bg-slate-50">
                                <td class="p-4 font-medium text-slate-900">#TW-101</td>
                                <td class="p-4">Product</td>
                                <td class="p-4">Dark mode support in analytics tab</td>
                                <td class="p-4 space-x-2">
                                    <button onclick="resolveItem(this)" class="bg-emerald-50 text-emerald-600 px-3 py-1 rounded-md text-xs font-semibold hover:bg-emerald-100 transition">Mark Resolved</button>
                                    <button onclick="deleteItem(this)" class="bg-red-50 text-red-600 px-3 py-1 rounded-md text-xs font-semibold hover:bg-red-100 transition">Delete</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- 6. Authentication Tab (Login / Register) -->
            <section id="tab-auth" class="tab-content hidden space-y-6">
                <div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow-sm border border-slate-200">
                    <div class="text-center mb-6">
                        <h1 class="text-2xl font-bold text-primary">Portal Authentication</h1>
                        <p class="text-sm text-slate-500 mt-1">Sign in as a User or Administrator</p>
                    </div>
                    <form onsubmit="handleLogin(event)" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                            <input type="email" id="login-email" required placeholder="user@wheeltrix.com" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                            <input type="password" id="login-pass" required placeholder="••••••••" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Select Role</label>
                            <select id="login-role" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent outline-none">
                                <option value="Standard User">Standard User</option>
                                <option value="Administrator">Administrator</option>
                            </select>
                        </div>
                        <button type="submit" class="w-full bg-accent text-white py-3 rounded-lg font-medium hover:bg-indigo-700 transition shadow-sm">Sign In</button>
                    </form>
                </div>
            </section>

        </main>
    </div>

    <!-- JavaScript Application Logic -->
    <script>
        function switchTab(tabId) {
            // Hide all tab content sections
            const tabs = document.querySelectorAll('.tab-content');
            tabs.forEach(tab => tab.classList.add('hidden'));

            // Show selected tab
            document.getElementById('tab-' + tabId).classList.remove('hidden');

            // Update sidebar active states
            const navButtons = document.querySelectorAll('.tab-btn');
            navButtons.forEach(btn => {
                btn.classList.remove('bg-accent', 'text-white');
                btn.classList.add('hover:bg-slate-800', 'hover:text-white');
            });

            const activeBtn = document.getElementById('nav-' + tabId);
            if(activeBtn) {
                activeBtn.classList.add('bg-accent', 'text-white');
                activeBtn.classList.remove('hover:bg-slate-800', 'hover:text-white');
            }
        }

        function handleFeedbackSubmit(event) {
            event.preventDefault();
            const category = document.getElementById('fb-category').value;
            const title = document.getElementById('fb-title').value;
            
            // Generate random tracking ID
            const id = '#TW-' + Math.floor(100 + Math.random() * 900);

            // Append to table dynamically
            const list = document.getElementById('my-feedback-list');
            const newRow = document.createElement('tr');
            newRow.className = 'hover:bg-slate-50';
            newRow.innerHTML = `
                <td class="p-4 font-medium text-slate-900">${id}</td>
                <td class="p-4">${category}</td>
                <td class="p-4">${title}</td>
                <td class="p-4"><span class="bg-amber-50 text-amber-600 px-2.5 py-1 rounded-full text-xs font-semibold">Pending</span></td>
            `;
            list.prepend(newRow);

            alert('Feedback submitted successfully! Tracking ID: ' + id);
            document.getElementById('feedbackForm').reset();
            switchTab('my-feedback');
        }

        function handleLogin(event) {
            event.preventDefault();
            const email = document.getElementById('login-email').value;
            const role = document.getElementById('login-role').value;

            document.getElementById('user-role-badge').innerText = role;
            document.getElementById('auth-btn-text').innerText = 'Logout';
            
            alert('Successfully logged in as ' + role);
            switchTab('dashboard');
        }

        function resolveItem(btn) {
            const row = btn.closest('tr');
            const statusCell = row.cells[3]; // adjusting based on structure if needed or toggle actions
            alert('Feedback marked as resolved.');
            row.remove();
        }

        function deleteItem(btn) {
            if(confirm('Are you sure you want to delete this feedback item?')) {
                btn.closest('tr').remove();
            }
        }
    </script>
</body>
</html>
